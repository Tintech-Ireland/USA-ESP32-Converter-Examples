# Route the console (stdout + ESP_LOG) to the native USB-Serial-JTAG port, so the
# board can be flashed AND monitored over its single USB connection.
# The RS232 example uses UART1 (GPIO5/GPIO4) for the link, so the console choice
# does not conflict with the protocol under test.
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
